{
	"name": "bitcamp-2026",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"start": "vite build && bun run server/app.ts",
		"dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
